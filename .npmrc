# React is pinned to 18.x (a firm, repo-wide rule — see CLAUDE.md security rules).
# react-chessboard v5.x declares a peer dependency on react@^19, but is used with
# React 18 here per the build plan. legacy-peer-deps lets install/ci proceed with
# the intended React 18 tree instead of failing on that peer range.
legacy-peer-deps=true
