# ─── LLM (coaching text) ───
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
CLAUDE_API_KEY=

# ─── External chess data ───
LICHESS_TOKEN=

# ─── Database (Turso; omit both locally to use file:squire.db) ───
TURSO_CONNECTION_URL=
TURSO_AUTH_TOKEN=

# ─── App / infra ───
FRONTEND_URL=http://localhost:5173
# PORT: optional — backend falls back to 3001 locally; Render injects its own (default 10000) in prod
PORT=3001
# VITE_API_URL: the backend origin the browser calls; keep its port matching PORT above
VITE_API_URL=http://localhost:3001
TRUST_PROXY_HOPS=
VERCEL_ACCOUNT_SLUG=
SENTRY_DSN=
LOG_LEVEL=info

# ─── Auth (Clerk) ───
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# ─── Account linking ───
LICHESS_OAUTH_CLIENT_ID=
LICHESS_OAUTH_REDIRECT_URI=
CHESSCOM_OAUTH_CLIENT_ID=
CHESSCOM_OAUTH_CLIENT_SECRET=
